# Next.js / Node
node_modules/
.next/
out/
.env
.env.local

# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Backend caches — regeneratable, do NOT commit.
backend/data/raw/
# Use `processed/*` (not `processed/`) so a `!file` exception below can
# unignore specific files. With a bare `processed/` rule git ignores the
# entire directory and SILENTLY overrides any `!file` exceptions inside —
# which is how park_factors.parquet failed to ship to CI on first deploy.
backend/data/processed/*
# EXCEPT: park_factors.parquet is small (~5KB) and expensive to rebuild
# (~20 min of Statcast pulls), so we commit it explicitly.
!backend/data/processed/park_factors.parquet
# AND: tracker.json — small, generated nightly, read at build time by
# /tracker page for the big-number metric cards.
!backend/data/processed/tracker.json
# AND: clv_recovered.csv — per-pick closing-line value, regenerated by the
# settle workflow each fire (idempotent full-window rebuild). Committed so
# review tooling can read CLV history without recomputing from snapshots.
!backend/data/processed/clv_recovered.csv
# AND: park_factor_counts.parquet — the raw HR/PA counts (by park, hand, source
# season) that scripts/build_park_factors.py regresses into park_factors.parquet.
# Committing it makes the factor rebuild reproducible WITHOUT a multi-hour
# Statcast re-pull (append a new season's counts, re-run the build).
!backend/data/processed/park_factor_counts.parquet

# DO commit backend/data/odds/ — those snapshots ARE our dataset.
# (No ignore for backend/data/odds.)

# Research artifacts (kept local; the chunk cache is GBs)
backend/data/research/

# Run logs / scratch
backend/*.log
*.log

# backend/picks.json is a workflow intermediate — the cron writes it then
# copies to repo-root /picks.json (which IS tracked).
backend/picks.json
backend/secondary_picks.json
backend/shadow_picks.json
